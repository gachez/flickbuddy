# TMDB
TMDB_API_KEY=

# Auth
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
DATABASE_PATH=./data/FlickBuddy.sqlite
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAILS=

# Beta limits
BETA_ANONYMOUS_AI_DISCOVER_DAILY_LIMIT=20
BETA_AUTHENTICATED_AI_DISCOVER_DAILY_LIMIT=80
BETA_AUTHENTICATED_AI_PROFILE_REFRESH_DAILY_LIMIT=6
BETA_ANONYMOUS_LEGACY_RECOMMENDATIONS_DAILY_LIMIT=10
BETA_AUTHENTICATED_LEGACY_RECOMMENDATIONS_DAILY_LIMIT=40

# AI provider routing
# Valid providers: openai, anthropic, google, azure-openai, azure-ai, openrouter, ollama
AI_PROVIDER=openai
AI_MODEL=gpt-4.1

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=FlickBuddy

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Azure AI Inference (serverless models: grok, deepseek)
AZURE_AI_API_KEY=
GROK_3_MINI_ENDPOINT=
DEEPSEEK_V3_ENDPOINT=
GROK_3_ENDPOINT=

# Azure Anthropic (Claude via REST)
AZURE_ANTHROPIC_API_KEY=
AZURE_ANTHROPIC_ENDPOINT=
